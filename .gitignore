import streamlit as st
import pandas as pd
import numpy as np
import plotly.graph_objects as go

st.set_page_config(page_title="BI Dashboard - Red Factory", layout="wide")
st.title("🏛️ Master Business Intelligence Dashboard")

with st.sidebar:
    st.header("⚙️ Instellingen")
    is_vrijgesteld = st.toggle("Bedrijf is BTW-vrijgesteld", value=False)
    uploaded_file = st.file_uploader("Upload Yuki CSV", type=['csv'])

if uploaded_file:
    # 1. DATA LADEN
    df = pd.read_csv(uploaded_file, sep=None, engine='python', encoding='iso-8859-1')
    df.columns = df.columns.str.strip()

    def clean_val(x):
        if pd.isna(x): return 0.0
        x = str(x).replace('"', '').replace('.', '').replace(',', '.')
        try: return float(x)
        except: return 0.0

    df['Amount_Clean'] = df['Bedrag'].apply(clean_val)
    df['Date'] = pd.to_datetime(df['Datum'], dayfirst=True, errors='coerce')
    df = df.dropna(subset=['Date']).sort_values('Date')
    df['Code_Str'] = df['Code'].astype(str).str.strip()

    # 2. ALLES SCANNEN (Vanaf 2016)
    df_omzet = df[df['Code_Str'].str.startswith('8')].copy()
    
    # Maak een tijdreeks over de gehele periode
    full_range = pd.date_range(start=df_omzet['Date'].min(), end=df_omzet['Date'].max(), freq='MS')
    monthly_series = df_omzet.set_index('Date')['Amount_Clean'].resample('MS').sum().abs()
    monthly_series = monthly_series.reindex(full_range).fillna(0)

    # REPARATIE: De Juli/Aug fix voor de hele historie
    # We vullen 0-waarden in met een voortschrijdend gemiddelde
    monthly_series_fixed = monthly_series.replace(0, np.nan).interpolate(method='linear').fillna(monthly_series.mean())

    # 3. BTW & MARGE (Red Factory Specifiek)
    # We zoeken naar BTW op omzet (vaak 18xxx codes)
    df_btw = df[df['Code_Str'].str.startswith('18')].copy()
    eff_btw = abs(df_btw['Amount_Clean'].sum()) / abs(df_omzet['Amount_Clean'].sum()) if not df_omzet.empty else 0.21
    if eff_btw < 0.05: eff_btw = 0.21 # Fallback naar 21%

    # Kosten scan
    df_kosten = df[df['Code_Str'].str.startswith(('4', '6', '7'))].copy()
    marge_ratio = (abs(df_omzet['Amount_Clean'].sum()) - abs(df_kosten['Amount_Clean'].sum())) / abs(df_omzet['Amount_Clean'].sum()) if not df_omzet.empty else 0.1

    # 4. PROGNOSE NAAR 2026
    # Omdat de data stopt in 2021, pakken we het historisch gemiddelde per jaar
    aantal_jaren = len(monthly_series_fixed) / 12
    totaal_historie = monthly_series_fixed.sum()
    prognose_basis = (totaal_historie / aantal_jaren) # Gemiddelde omzet per jaar
    
    # Seizoen opbouwen uit alle jaren (gemiddelde per maand-index)
    seasonal_pattern = monthly_series_fixed.groupby(monthly_series_fixed.index.month).mean()
    forecast_2026 = [(seasonal_pattern.get(m, seasonal_pattern.mean()) / seasonal_pattern.sum()) * prognose_basis for m in range(1, 13)]
    future_dates = pd.date_range(start=pd.Timestamp(2026, 1, 1), periods=12, freq='MS')

    # --- DASHBOARD ---
    st.subheader(f"📊 Analyse: 0165 Red Factory ({aantal_jaren:.1f} jaar historie)")
    
    k1, k2, k3 = st.columns(3)
    k1.metric("Verwachte Jaaromzet", f"€ {prognose_basis:,.2f}")
    k2.metric("Verwachte Winst", f"€ {(prognose_basis * marge_ratio):,.2f}")
    k3.metric("Effectieve BTW", f"{(eff_btw*100):.1f}%")

    st.markdown("---")
    st.subheader("📈 Meerjarige Trendlijn (Zonder Juli-gaten)")
    fig = go.Figure()
    # De historische data (Blauw)
    fig.add_trace(go.Bar(x=monthly_series_fixed.index, y=monthly_series_fixed.values, name="Historie (Gefilterd)", marker_color='#1f77b4'))
    # De prognose voor 2026 (Oranje)
    fig.add_trace(go.Bar(x=future_dates, y=forecast_2026, name="Prognose 2026", marker_color='#ff7f0e'))
    
    fig.update_layout(template="plotly_white", barmode='group', height=500, xaxis_title="Tijdslijn 2016 - 2026")
    st.plotly_chart(fig, use_container_width=True)

    # BTW & DETAILS
    c1, c2 = st.columns(2)
    with c1:
        st.subheader("🏦 BTW Reservering 2026")
        q_data = []
        for q in range(1, 5):
            m_idx = [0,1,2] if q==1 else [3,4,5] if q==2 else [6,7,8] if q==3 else [9,10,11]
            q_rev = sum([forecast_2026[i] for i in m_idx])
            q_data.append({"Kwartaal": f"Q{q}", "Omzet": f"€ {q_rev:,.0f}", "BTW": f"€ {q_rev*eff_btw:,.2f}"})
        st.table(pd.DataFrame(q_data))

    with c2:
        st.subheader("🍕 Kostenverdeling Historie")
        k_labels = ['Bedrijfskosten (4)', 'Inkoop (6)', 'Overig (7)']
        k_vals = [abs(df[df['Code_Str'].str.startswith('4')]['Amount_Clean'].sum()),
                  abs(df[df['Code_Str'].str.startswith('6')]['Amount_Clean'].sum()),
                  abs(df[df['Code_Str'].str.startswith('7')]['Amount_Clean'].sum())]
        st.plotly_chart(go.Figure(data=[go.Pie(labels=k_labels, values=k_vals, hole=.3)]), use_container_width=True)

else:
    st.info("Upload de Yuki CSV van Red Factory.")
